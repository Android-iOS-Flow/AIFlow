# Sao chép thành `.env` rồi điền giá trị:  cp .env.example .env
# Tất cả biến ở đây CHỈ là giá trị MẶC ĐỊNH ban đầu — web UI (Settings) sẽ
# ghi đè và lưu vào config.json. Bí mật (key) nên để ở đây thay vì commit config.json.

# --- Supabase (đọc flow công khai qua REST) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Chỉ dùng publishable/anon key — KHÔNG bao giờ service_role ở client/remote.
SUPABASE_PUBLISHABLE_KEY=

# --- Ably (nhận lệnh "Run" từ web app) ---
ABLY_API_KEY=
ABLY_CHANNEL=flow-run

# --- Web UI ---
REMOTE_HOST=127.0.0.1
REMOTE_PORT=8765
# Đổi nếu muốn mở UI từ máy khác / điện thoại khác trong LAN: REMOTE_HOST=0.0.0.0

# --- Thiết bị / ADB ---
# Để trống = tự dò `adb` trong PATH. Trên Termux có thể là /data/data/com.termux/files/usr/bin/adb
ADB_PATH=
# Serial thiết bị khi cắm nhiều máy (adb -s <serial>). Để trống nếu chỉ 1 máy.
DEVICE_SERIAL=
# Driver thực thi: adb | dummy   (dummy chỉ log, không điều khiển thật — để test)
DRIVER=adb
