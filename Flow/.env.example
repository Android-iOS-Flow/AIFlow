# Supabase (lấy ở Dashboard > Project Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Ably (realtime) — dùng cho nút Run
VITE_ABLY_API_KEY=xxxx.yyyy:zzzz
# Kênh publish khi bấm Run (tuỳ chọn, mặc định "flow-run")
VITE_ABLY_CHANNEL=flow-run
